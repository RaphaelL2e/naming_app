.container {
  padding: 40rpx;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.generate-btn {
  background: #fff;
  color: #11998e;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 25rpx;
  margin-bottom: 40rpx;
}

.result-section {
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.name-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.name-item {
  background: #f8f8f8;
  border-radius: 15rpx;
  padding: 25rpx;
}

.name-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.name-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #11998e;
}

.star {
  color: #ff9800;
  font-size: 24rpx;
}

.name-meaning {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tips {
  background: rgba(255,255,255,0.2);
  border-radius: 15rpx;
  padding: 25rpx;
}

.tips-title {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.tips-content {
  color: rgba(255,255,255,0.9);
  font-size: 24rpx;
  line-height: 1.6;
}