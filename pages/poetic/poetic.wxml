<view class="container">
  <view class="header">
    <text class="title">📜 诗意取名</text>
    <text class="subtitle">从唐诗宋词中寻找好名字</text>
  </view>

  <button class="generate-btn" bindtap="generatePoetic">生成诗意名字</button>

  <view class="result-section" wx:if="{{names.length > 0}}">
    <text class="result-title">诗意推荐：</text>
    <view class="name-list">
      <block wx:for="{{names}}" wx:key="index">
        <view class="name-item" bindtap="addToFavorites" data-name="{{item.name}}" data-meaning="{{item.meaning}}">
          <view class="name-main">
            <text class="name-text">{{item.name}}</text>
            <text class="star">⭐ 收藏</text>
          </view>
          <text class="name-meaning">{{item.meaning}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="tips">
    <text class="tips-title">💡 小贴士</text>
    <text class="tips-content">点击名字可收藏到本地，下次打开小程序就能看到收藏的名字啦～</text>
  </view>
</view>