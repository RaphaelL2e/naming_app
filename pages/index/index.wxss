.container {
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.input-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.surname-input {
  font-size: 36rpx;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
}

.generate-btn {
  background: #ffd700;
  color: #333;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 25rpx;
  margin-bottom: 40rpx;
}

.result-section {
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  padding: 30rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.name-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.name-item {
  width: 45%;
  background: #f5f5f5;
  border-radius: 15rpx;
  padding: 20rpx;
}

.name-text {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  text-align: center;
}

.name-meaning {
  display: block;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-top: 10rpx;
}