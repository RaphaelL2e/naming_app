.container {
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.input-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.surname-input {
  font-size: 36rpx;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
}

.gender-section {
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.gender-option {
  display: inline-flex;
  align-items: center;
  margin-right: 40rpx;
  color: #fff;
  font-size: 28rpx;
}

.generate-btn {
  background: #ffd700;
  color: #333;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 25rpx;
  margin-bottom: 40rpx;
}

.result-section {
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  padding: 30rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.name-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.name-item {
  background: #f8f8f8;
  border-radius: 15rpx;
  padding: 25rpx;
}

.name-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.name-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

.score-badge {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.name-meaning {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.name-origin {
  display: block;
  font-size: 24rpx;
  color: #999;
  font-style: italic;
}